    ],
    "category": "Text",
    "text": "Với $t = 0$ thì $v(0) = 2\\sin\\left(\\frac{\\pi}{6}\\right) = 1$ (cm/s)."
  },
  {
    "bbox": [
      217,
      1504,
      441,
