"[{\"bbox\": [193, 51, 227, 91], \"category\": \"Picture\"}, {\"bbox\": [241, 51, 858, 94], \"category\": \"Page-header\", \"text\": \"Bộ đề ôn thi THPT Quốc Gia 2026 - Part 2\"}, {\"bbox\": [1261, 54, 1448, 96], \"category\": \"Page-header\", \"text\": \"Ngô Đức Tài\"}, {\"bbox\": [281, 156, 532, 199], \"category\": \"Section-header\", \"text\": \"ĐỀ THAM KHẢO\"}, {\"bbox\": [343, 211, 475, 251], \"category\": \"Text\", \"text\": \"ĐỀ SỐ 10\"}, {\"bbox\": [278, 265, 540, 312], \"category\": \"Text\", \"text\": \"(Đề gồm 5 trang)\"}, {\"bbox\": [773, 153, 1314, 198], \"category\": \"Section-header\", \"text\": \"KÌ THI TỐT NGHIỆP THPT QUỐC GIA\"}, {\"bbox\": [960, 213, 1129, 247], \"category\": \"Text\", \"text\": \"Môn: TOÁN\"}, {\"bbox\": [667, 263, 1426, 310], \"category\": \"Text\", \"text\": \"Thời gian làm bài: 90 phút, không kể thời gian phát đề\"}, {\"bbox\": [193, 365, 1452, 483], \"category\": \"Text\", \"text\": \"PHẦN I. Câu trắc nghiệm nhiều phương án lựa chọn. Thí sinh trả lời từ câu 1 đến câu 12. Mỗi câu hỏi thí sinh chỉ chọn một phương án.\"}, {\"bbox\": [193, 506, 913, 635], \"category\": \"Text\", \"text\": \"Câu 1. Nếu $\\\\int_{1}^{3} f(x) \\\\, dx = 5$ thì $\\\\int_{1}^{3} 2f(x) \\\\, dx$ bằng\"}, {\"bbox\": [223, 639, 305, 720], \"category\": \"List-item\", \"text\": \"A. $\\\\frac{5}{2}$.\"}, {\"bbox\": [525, 661, 598, 695], \"category\": \"List-item\", \"text\": \"B. 7.\"}, {\"bbox\": [826, 661, 899, 695], \"category\": \"List-item\", \"text\": \"C. 4.\"}, {\"bbox\": [1127, 661, 1218, 695], \"category\": \"List-item\", \"text\": \"D. 10.\"}, {\"bbox\": [193, 732, 1417, 781], \"category\": \"Text\", \"text\": \"Câu 2. Cho cấp số nhân ($u_n$) với $u_1 = 3$ và công bội $q = -2$. Giá trị của $u_4$ bằng\"}, {\"bbox\": [223, 800, 315, 834], \"category\": \"List-item\", \"text\": \"A. 12.\"}, {\"bbox\": [525, 800, 616, 834], \"category\": \"List-item\", \"text\": \"B. 24.\"}, {\"bbox\": [826, 800, 946, 834], \"category\": \"List-item\", \"text\": \"C. $-24$.\"}, {\"bbox\": [1127, 800, 1247, 834], \"category\": \"List-item\", \"text\": \"D. $-12$.\"}, {\"bbox\": [193, 868, 1454, 970], \"category\": \"Text\", \"text\": \"Câu 3. Cho khối集合 có diện tích đáy là $B$ và chiều cao là $3h$. Thế tích $V$ của khối集合 đã cho là\"}, {\"bbox\": [223, 974, 420, 1054], \"category\": \"List-item\", \"text\": \"A. $V = \\\\frac{1}{3}Bh$.\"}, {\"bbox\": [525, 995, 698, 1030], \"category\": \"List-item\", \"text\": \"B. $V = Bh$.\"}, {\"bbox\": [826, 995, 1017, 1030], \"category\": \"List-item\", \"text\": \"C. $V = 3Bh$.\"}, {\"bbox\": [1127, 974, 1324, 1054], \"category\": \"List-item\", \"text\": \"D. $V = \\\\frac{1}{6}Bh$.\"}, {\"bbox\": [193, 1088, 859, 1296], \"category\": \"Text\", \"text\": \"Câu 4. Cho hàm số $y = f(x)$ liên tục trên đoạn $[1; 5]$ và có đồ thị trên như hình vẽ sau: Trên đoạn $[1; 5]$, hàm số đã cho đạt giá trị lớn nhất tại điểm\"}, {\"bbox\": [223, 1318, 822, 1354], \"category\": \"List-item\", \"text\": \"A. $x = 4$. B. $x = 1$. C. $x = 2$. D. $x = 5$.\"}, {\"bbox\": [878, 1097, 1444, 1595], \"category\": \"Picture\"}, {\"bbox\": [193, 1612, 1454, 1712], \"category\": \"Text\", \"text\": \"Câu 5. Trong không gian $Oxyz$, điểm $M'$ đối xứng với điểm $M(2; 3; -4)$ qua gốc toạ độ $O$ có toạ độ là\"}, {\"bbox\": [223, 1730, 788, 1774], \"category\": \"List-item\", \"text\": \"A. $M'(-2; -3; -4)$.\"}, {\"bbox\": [826, 1730, 1087, 1774], \"category\": \"List-item\", \"text\": \"B. $M'(-2; -3; 4)$.\"}, {\"bbox\": [1127, 1730, 1334, 1774], \"category\": \"List-item\", \"text\": \"C. $M'(-2; 3; -4)$.\"}, {\"bbox\": [1127, 1730, 1334, 1774], \"category\": \"List-item\", \"text\": \"D. $M'(2; 3; 4)$.\"}, {\"bbox\": [193, 1796, 1273, 1881], \"category\": \"Text\", \"text\": \"Câu 6. Cho hàm số $f(x) = 1 - \\\\frac{1}{\\\\cos^2 x}$. Khẳng định nào sau đây đúng?\"}, {\"bbox\": [223, 1881, 676, 1957], \"category\": \"List-item\", \"text\": \"A. $\\\\int f(x) \\\\, dx = x + \\\\tan x + C$.\"}, {\"bbox\": [834, 1881, 12