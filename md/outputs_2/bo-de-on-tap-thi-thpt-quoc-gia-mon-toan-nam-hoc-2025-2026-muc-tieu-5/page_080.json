    "text": "<table><tr><td>$x$</td><td>$-1$</td><td>0</td><td>2</td><td>3</td></tr><tr><td>$f'(x)$</td><td>+</td><td>0</td><td>-</td><td>0</td><td>+</td></tr><tr><td>$f(x)$</td><td>0</td><td>5</td><td>1</td><td>4</td></tr></table>"
  },
  {
    "bbox": [
