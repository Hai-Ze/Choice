"[{\"bbox\": [258, 139, 1017, 182], \"category\": \"Text\", \"text\": \"★ Khi $x$ tăng từ 0 đến 7, $f(x)$ tăng từ 0 đến $S_1 > 0$.\"}, {\"bbox\": [258, 190, 1547, 278], \"category\": \"Text\", \"text\": \"★ Khi $x$ tăng từ 7 đến 10, $f(x)$ giảm từ $S_1$ xuống $f(10) = S_1 - S_2$. Dựa vào hình vẽ, diện tích $S_1$ lớn hơn $S_2$, do đó $f(10) > 0$. Như vậy trên $(0, 10]$, $f(x)$ luôn dương.\"}, {\"bbox\": [258, 286, 1547, 374], \"category\": \"Text\", \"text\": \"★ Khi $x$ tăng từ 10 đến 14, $f(x)$ tăng từ $f(10)$ lên đến $f(14) = S_1 - S_2 + S_3$. Vì $f(10) > 0$ và $S_3 > 0$ nên $f(x) > 0$ với mọi $x \\\\in (10, 14]$.\"}, {\"bbox\": [234, 388, 1375, 432], \"category\": \"Text\", \"text\": \"Vậy phương trình $f(x) = 0$ chỉ có duy nhất một nghiệm $x = 0$ trên đoạn $[0; 14]$.\"}, {\"bbox\": [152, 450, 1547, 581], \"category\": \"Text\", \"text\": \"### 2.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.8.