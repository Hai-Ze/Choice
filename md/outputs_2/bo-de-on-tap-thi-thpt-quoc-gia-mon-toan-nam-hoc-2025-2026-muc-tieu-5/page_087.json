"[{\"bbox\": [203, 140, 765, 182], \"category\": \"Text\", \"text\": \"10 phút đầu, máy bay bay từ $C$ đến $Q$;\"}, {\"bbox\": [153, 200, 1547, 289], \"category\": \"Text\", \"text\": \"20 phút tiếp theo, máy bay bay từ $Q \\\\to Q'$ với vận tốc không đổi và bay ngang cùng chiều với tia $Oy$ (có vectơ chỉ phương là $\\\\vec{j} = (0; 1; 0)$).\"}, {\"bbox\": [203, 306, 1231, 348], \"category\": \"Text\", \"text\": \"Khi đó khoảng cách cần tính là $CQ'$. Do đó, ta cần tìm tọa độ điểm $Q'$.\"}, {\"bbox\": [153, 360, 1544, 503], \"category\": \"Text\", \"text\": \"Máy bay bay với vận tốc không đổi 3 km/phút và chuyển động cùng hướng với vectơ $\\\\vec{j} = (0; 1; 0)$ nên có vectơ vận tốc là $\\\\vec{v} = 3 \\\\cdot \\\\frac{\\\\vec{j}}{|\\\\vec{j}|} = 3 \\\\cdot \\\\frac{(0; 1; 0)}{\\\\sqrt{0^2 + 1^2 + 0^2}} = (0; 3; 0)$.\"}, {\"bbox\": [203, 518, 1212, 560], \"category\": \"Text\", \"text\": \"Vì ban đầu máy bay ở $Q(-4; 20; 10)$ nên sau 20 phút, máy bay ở vị trí\"}, {\"bbox\": [203, 577, 1006, 621], \"category\": \"Formula\", \"text\": \"$$\\nQ' = Q + 20 \\\\cdot \\\\vec{v} = (-4; 20 + 20 \\\\cdot 3; 10) \\\\Rightarrow Q'(-4; 80; 10).\\n$$\"}, {\"bbox\": [203, 634, 1453, 684], \"category\": \"Formula\", \"text\": \"$$\\n\\\\text{Vậy } CQ' = \\\\sqrt{(-4 - 16)^2 + 80^2 + 10^2} = \\\\sqrt{400 + 6400 + 100} = \\\\sqrt{6900} \\\\approx 83 \\\\text{ km} > 80 \\\\text{ km.}\\n$$\"}, {\"bbox\": [153, 703, 1547, 830], \"category\": \"Text\", \"text\": \"### 4.9.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4