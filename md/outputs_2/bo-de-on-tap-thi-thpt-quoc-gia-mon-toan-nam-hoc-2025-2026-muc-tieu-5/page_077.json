"[{\"bbox\": [202, 139, 1547, 183], \"category\": \"Text\", \"text\": \"Sau $t_0$ ngày ($0 < t_0 < 15$), hai cây hoa có chiều cao bằng nhau khi và chỉ khi $h_2(t_0) - h_1(t_0) = 0$\"}, {\"bbox\": [413, 188, 1285, 281], \"category\": \"Formula\", \"text\": \"$$\\n\\\\Leftrightarrow \\\\int_{0}^{t_0} h'_{2}(t) dt - \\\\int_{0}^{t_0} h'_{1}(t) dt = 0 \\\\Leftrightarrow \\\\int_{0}^{t_0} [h'_{2}(t) - h'_{1}(t)] dt = 0\\n$$\"}, {\"bbox\": [450, 290, 1248, 387], \"category\": \"Formula\", \"text\": \"$$\\n\\\\Leftrightarrow \\\\int_{0}^{t_0} (4e^{-0,1t} - e^{0,1t}) dt = 0 \\\\Leftrightarrow \\\\left( \\\\frac{4e^{-0,1t}}{-0,1} - \\\\frac{e^{0,1t}}{0,1} \\\\right) \\\\bigg|_{0}^{t_0} = 0\\n$$\"}, {\"bbox\": [637, 395, 1063, 492], \"category\": \"Formula\", \"text\": \"$$\\n\\\\Leftrightarrow (-40e^{-0,1t} - 10e^{0,1t}) \\\\bigg|_{0}^{t_0} = 0\\n$$\"}, {\"bbox\": [491, 498, 1205, 544], \"category\": \"Formula\", \"text\": \"$$\\n\\\\Leftrightarrow -40e^{-0,1t_0} - 10e^{0,1t_0} - (-40e^{0,1 \\\\cdot 0} - 10e^{0,1 \\\\cdot 0}) = 0\\n$$\"}, {\"bbox\": [528, 558, 1167, 604], \"category\": \"Formula\", \"text\": \"$$\\n\\\\Leftrightarrow -40e^{-0,1t_0} - 10e^{0,1t_0} - (-40e^{0} - 10e^{0}) = 0\\n$$\"}, {\"bbox\": [618, 618, 1079, 660], \"category\": \"Formula\", \"text\": \"$$\\n\\\\Leftrightarrow -40e^{-0,1t_0} - 10e^{0,1t_0} + 50 = 0\\n$$\"}, {\"bbox\": [202, 685, 559, 725], \"category\": \"Text\", \"text\": \"Nhân cả hai vế với $e^{0,1t_0}$:\"}, {\"bbox\": [616, 739, 1081, 784], \"category\": \"Formula\", \"text\": \"$$\\n-10(e^{0,1t_0})^2 + 50e^{0,1t_0} - 40e^0 = 0\\n$$\"}, {\"bbox\": [154, 808, 1547, 896], \"category\": \"Text\", \"text\": \"(Coi $e^{0,1t_0}$ tương đương với biến $x$, khi đó ta bấm máy tính tìm nghiệm phương trình bậc hai để tìm nghiệm $e^{0,1t_0}$):\"}, {\"bbox\": [365, 902, 1331, 1038], \"category\": \"Formula\", \"text\": \"$$\\n\\\\Leftrightarrow \\\\begin{cases} e^{0,1t_0} = 4 \\\\\\\\ e^{0,1t_0} = 1 \\\\end{cases} \\\\Leftrightarrow \\\\begin{cases} 0,1t_0 = \\\\ln 4 \\\\\\\\ 0,1t_0 = \\\\ln 1 \\\\end{cases} \\\\Leftrightarrow \\\\begin{cases} t_0 = \\\\frac{\\\\ln 4}{0,1} = 10 \\\\ln 4 \\\\in (0; 15) \\\\text{ (tm)} \\\\\\\\ t_0 = 0 \\\\notin (0; 15) \\\\text{ (l)} \\\\end{cases}\\n$$\"}, {\"bbox\": [202, 1063, 1259, 1105], \"category\": \"Text\", \"text\": \"Vậy sau $t_0 = 10 \\\\ln 4$ ngày thì hai cây hoa có chiều cao bằng nhau và bằng:\"}, {\"bbox\": [598, 1117, 1097, 1161], \"category\": \"Formula\", \"text\": \"$$\\nh_1(10 \\\\ln 4) = 10e^{0,1 \\\\cdot 10 \\\\ln 4} = 40 \\\\text{ (cm).}\\n$$\"}, {\"bbox\": [154, 1188, 1547, 1451], \"category\": \"Text\", \"text\": \"### 3.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.