      777
    ],
    "category": "Text",
    "text": "Số điểm cực trị của hàm số $y = f(x)$ là"
  },
  {
    "bbox": [
      191,
      795,
      274,
      838
    ],
    "category": "List-item",
    "text": "A) 2."
  },
  {
    "bbox": [
      535,
      795,
      617,
      838
    ],
    "category": "List-item",
    "text": "B) 1."
  },
  {
    "bbox": [
