    ],
    "category": "Table",
    "text": "<table><tr><td>$x$</td><td>$-\\infty$</td><td>$-3$</td><td>$1$</td><td>$2$</td><td>$+\\infty$</td></tr><tr><td>$f'(x)$</td><td colspan=\"5\">$- \\quad 0 \\quad + \\quad 0 \\quad + \\quad 0 \\quad -$</td></tr></table>"
  },
  {
    "bbox": [
      154,
