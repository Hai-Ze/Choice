"[{\"bbox\": [154, 134, 198, 176], \"category\": \"Picture\"}, {\"bbox\": [204, 134, 1132, 198], \"category\": \"Text\", \"text\": \"Hướng dẫn giải. Vectơ $\\\\overrightarrow{BC} = (1 - 0; -1 - 2; 2 - 1) = (1; -3; 1)$.\"}, {\"bbox\": [204, 198, 1164, 240], \"category\": \"Text\", \"text\": \"Mặt phẳng vuông góc với $BC$ nên nhận $\\\\overrightarrow{BC}$ làm vectơ pháp tuyến.\"}, {\"bbox\": [204, 244, 1522, 286], \"category\": \"Text\", \"text\": \"Phương trình mặt phẳng đi qua $A(1; 1; 1)$ là: $1(x-1)-3(y-1)+1(z-1) = 0 \\\\Leftrightarrow x-3y+z+1 = 0$.\"}, {\"bbox\": [154, 318, 198, 354], \"category\": \"Picture\"}, {\"bbox\": [204, 298, 992, 376], \"category\": \"Text\", \"text\": \"Câu 12. Heo nguyên hàm của hàm số $f(x) = e^{2x} + \\\\frac{3}{x}$ là\"}, {\"bbox\": [190, 388, 655, 469], \"category\": \"Formula\", \"text\": \"$$\\n\\\\text{A} \\\\quad \\\\int f(x)dx = e^{2x} + 3 \\\\ln x + C.\\n$$\"}, {\"bbox\": [877, 388, 1369, 469], \"category\": \"Formula\", \"text\": \"$$\\n\\\\text{B} \\\\quad \\\\int f(x)dx = \\\\frac{e^{2x}}{2} + 3 \\\\ln |x| + C.\\n$$\"}, {\"bbox\": [190, 467, 662, 549], \"category\": \"Formula\", \"text\": \"$$\\n\\\\text{C} \\\\quad \\\\int f(x)dx = \\\\frac{e^{2x}}{2} + 3 \\\\ln x + C.\\n$$\"}, {\"bbox\": [877, 467, 1360, 549], \"category\": \"Formula\", \"text\": \"$$\\n\\\\text{D} \\\\quad \\\\int f(x)dx = e^{2x} + 3 \\\\ln |x| + C.\\n$$\"}, {\"bbox\": [154, 566, 198, 602], \"category\": \"Picture\"}, {\"bbox\": [204, 547, 1096, 627], \"category\": \"Text\", \"text\": \"Hướng dẫn giải. Ta có $\\\\int \\\\left( e^{2x} + \\\\frac{3}{x} \\\\right) dx = \\\\frac{1}{2}e^{2x} + 3 \\\\ln |x| + C$.\"}, {\"bbox\": [154, 644, 1547, 730], \"category\": \"Text\", \"text\": \"Phần II. Câu trắc nghiệm đúng sai Thí sinh trả lời từ câu 1 đến câu 4. Mỗi ý a) b) c) d) thí sinh chọn đúng hoặc sai\"}, {\"bbox\": [154, 762, 190, 790], \"category\": \"Picture\"}, {\"bbox\": [198, 751, 1529, 792], \"category\": \"Text\", \"text\": \"Bài 1. Cho hàm số $y = -x^3 + 3x^2 + 4$ có đồ thị ($C$). Xét tính đúng sai của các    \n\n\n\"}, {\"bbox\": [190, 812, 1019, 854], \"category\": \"List-item\", \"text\": \"a) Tập xác định của hàm số là $\\\\mathcal{D} = \\\\mathbb{R}$ và $y' = -3x^3 + 6x$.\"}, {\"bbox\": [190, 868, 766, 910], \"category\": \"List-item\", \"text\": \"b) Hàm số đồng biến trên khoảng $(0; 2)$.\"}, {\"bbox\": [190, 922, 1547, 1008], \"category\": \"List-item\", \"text\": \"c) Đồ thị ($C$) có hai điểm cực trị và phương trình đường thẳng đi qua 2 điểm cực trị là $2x + y - 4 = 0$.\"}, {\"bbox\": [190, 1022, 1544, 1064], \"category\": \"List-item\", \"text\": \"d) Diện tích của tam giác $OAB$ bằng 4, với $O$ là gốc tọa độ và $A, B$ là các điểm cực trị của ($C$).\"}, {\"bbox\": [154, 1084, 198, 1120], \"category\": \"Picture\"}, {\"bbox\": [204, 1080, 911, 1142], \"category\": \"Text\", \"text\": \"Hướng dẫn giải. Xét hàm số $y = -x^3 + 3x^2 + 4$.\"}, {\"bbox\": [204, 1159, 907, 1199], \"category\": \"Text\", \"text\": \"Tập xác định của hàm số đa thức luôn là $\\\\mathcal{D} = \\\\mathbb{R}$.\"}, {\"bbox\": [204, 1217, 1032, 1259], \"category\": \"Text\", \"text\": \"Đạo hàm của hàm số: $y' = (-x^3 + 3x^2 + 4)' = -3x^2 + 6x$.\"}, {\"bbox\": [204, 1279, 1042, 1321], \"category\": \"Text\", \"text\": \"Mind đề ghi $y' = -3x^3 + 6x$ là **Sai** (sai số му của biến $x$).\"}, {\"bbox\": [204, 1339, 1050, 1435], \"category\": \"Text\", \"text\": \"Cho $y' = 0 \\\\Leftrightarrow -3x^2 + 6x = 0 \\\\Leftrightarrow -3x(x - 2) = 0 \\\\Leftrightarrow \\\\begin{cases} x = 0 \\\\\\\\ x = 2 \\\\end{cases}$.\"}, {\"bbox\": [204, 1454, 442, 1496], \"category\": \"Text\", \"text\": \"Bảng xét dấu $y'$:\"}, {\"bbox\": [467, 1502, 1232, 1662], \"category\": \"Table\", \"text\": \"<table><tr><td>$x$</td><td>$-\\\\infty$</td><td>0</td><td>2</td><td>$+\\\\infty$</td></tr><tr><td>$y'$</td><td>$-$</td><td>0</td><td>+</td><td>$-$</td></tr></table>\"}, {\"bbox\": [154, 1684, 1248, 1726], \"category\": \"Text\", \"text\": \"Trong khoảng $(0; 2)$, ta thấy $y' > 0$ nên hàm số đồng biến trên khoảng $(0; 2)$.\"}, {\"bbox\": [204, 1746, 436, 1786], \"category\": \"Text\", \"text\": \"Vậy ý b) **Đúng**.\"}, {\"bbox\": [204, 1804, 887, 1846], \"category\": \"Text\", \"text\": \"Từ bảng xét dấu, hàm số có hai điểm cực trị là:\"}, {\"bbox\": [196, 1866, 819, 1908], \"category\": \"Formula\", \"text\": \"$$\\n\\\\text{Điểm cực tiểu: } x = 0 \\\\Rightarrow y = 4 \\\\Rightarrow A(0; 4).\\n$$\"}, {\"bbox\": [196, 1924, 1098, 1966], \"category\": \"Formula\", \"text\": \"$$\\n\\\\text{Điểm cực đại: } x = 2 \\\\Rightarrow y = -(2)^3 + 3(2)^2 + 4 = 8 \\\\Rightarrow B(2; 8).\\n$$\"}, {\"bbox\": [154, 1986, 1138, 2028], \"category\": \"Text\", \"text\": \"Phương trình đường thẳng đi qua hai điểm cực trị $A(0; 4)$ và $B(2; 8)$:\"}, {\"bbox\": [204, 2044, 981, 2096], \"category\": \"Formula\", \"text\": \"$$\\n\\\\frac{x-0}{2-0} = \\\\frac{y-4}{8-4} \\\\Leftrightarrow \\\\frac{x}{2} = \\\\frac{y-4}{4} \\\\Leftrightarrow 2x = y - 4 \\\\Leftrightarrow 2x - y + 4 = 0.\\n$$\"}, {\"bbox\": [204, 2110, 1234, 2152], \"category\": \"Text\", \"text\": \"Mind đề ghi phương trình là $2x + y - 4 = 0$ là **Sai** (sai dấu của biến $y$).\"}, {\"bbox\": [204, 2170, 1123, 2212], \"category\": \"Text\", \"text\": \"Tọa độ các điểm cực trị là $A(0; 4)$, $B(2; 8)$ và gốc tọa độ $O(0; 0)$.\"}, {\"bbox\": [154, 2255, 185, 2289], \"category\": \"Picture\"}, {\"bbox\": [190, 2253, 829, 2295], \"category\": \"Page-footer\", \"text\": \"» Sưu tầm và Biên soạn: Lê Minh Kha - 0399653362\"}, {\"bbox\": [1561, 2251, 1598, 2281], \"category\": \"Page-footer\", \"text\": \"83\"}]"