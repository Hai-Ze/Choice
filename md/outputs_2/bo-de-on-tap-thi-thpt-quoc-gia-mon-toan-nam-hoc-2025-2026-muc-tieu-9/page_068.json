"[{\"bbox\": [467, 135, 1220, 252], \"category\": \"Table\", \"text\": \"<table><tr><td>Mức thưởng</td><td>[5; 10)</td><td>[10; 15)</td><td>[15; 20)</td><td>[20; 25)</td></tr><tr><td>Số công nhân</td><td>13</td><td>35</td><td>47</td><td>25</td></tr></table>\"}, {\"bbox\": [154, 261, 1037, 303], \"category\": \"Text\", \"text\": \"Mốt của dữ liệu ghép nhóm gần nhất với giá trị nào sau đây?\"}, {\"bbox\": [192, 322, 337, 364], \"category\": \"List-item\", \"text\": \"A 17, 76.\"}, {\"bbox\": [535, 322, 681, 364], \"category\": \"List-item\", \"text\": \"B 16, 67.\"}, {\"bbox\": [879, 322, 1026, 364], \"category\": \"List-item\", \"text\": \"C 17, 67.\"}, {\"bbox\": [1224, 322, 1369, 364], \"category\": \"List-item\", \"text\": \"D 16, 76.\"}, {\"bbox\": [154, 379, 1391, 442], \"category\": \"Text\", \"text\": \"Hướng dẫn giải. Nhóm chứa mốt là nhóm [15; 20) vì có tần số lớn nhất ($n_j = 47$).\"}, {\"bbox\": [154, 442, 774, 482], \"category\": \"Text\", \"text\": \"Ta có: $L = 15, h = 5, n_{j-1} = 35, n_{j+1} = 25$.\"}, {\"bbox\": [154, 478, 1220, 561], \"category\": \"Formula\", \"text\": \"$$\\nM_o = 15 + \\\\frac{47 - 35}{(47 - 35) + (47 - 25)} \\\\cdot 5 = 15 + \\\\frac{12}{12 + 22} \\\\cdot 5 = 15 + \\\\frac{60}{34} \\\\approx 16,76.\\n$$\"}, {\"bbox\": [154, 574, 1546, 664], \"category\": \"Text\", \"text\": \"Câu 5. Cho hình chóp $S.ABCD$ có đáy $ABCD$ là hình vuông cạnh bằng $a$; $SA = a\\\\sqrt{2}$ vuông góc với mặt phẳng ($ABCD$). Góc giữa đường thẳng $SC$ và mặt phẳng ($ABCD$) bằng\"}, {\"bbox\": [668, 678, 1034, 1015], \"category\": \"Picture\"}, {\"bbox\": [192, 1104, 302, 1146], \"category\": \"List-item\", \"text\": \"A 30°.\"}, {\"bbox\": [535, 1104, 645, 1146], \"category\": \"List-item\", \"text\": \"B 45°.\"}, {\"bbox\": [879, 1104, 986, 1146], \"category\": \"List-item\", \"text\": \"C 60°.\"}, {\"bbox\": [1224, 1104, 1334, 1146], \"category\": \"List-item\", \"text\": \"D 90°.\"}, {\"bbox\": [154, 1161, 1365, 1224], \"category\": \"Text\", \"text\": \"Hướng dẫn giải. Vì $SA \\\\perp (ABCD)$ nên $AC$ là hình chiếu của $SC$ lên ($ABCD$).\"}, {\"bbox\": [154, 1222, 591, 1268], \"category\": \"Text\", \"text\": \"Do đó $(SC, (ABCD)) = \\\\widehat{SCA}$.\"}, {\"bbox\": [154, 1268, 742, 1312], \"category\": \"Text\", \"text\": \"Đáy là hình vuông cạnh $a \\\\Rightarrow AC = a\\\\sqrt{2}$.\"}, {\"bbox\": [154, 1312, 1461, 1357], \"category\": \"Text\", \"text\": \"Tam giác $SAC$ vuông tại $A$ có $SA = AC = a\\\\sqrt{2} \\\\Rightarrow \\\\triangle SAC$ vuông cân tại $A \\\\Rightarrow \\\\widehat{SCA} = 45°$.\"}, {\"bbox\": [154, 1377, 1546, 1462], \"category\": \"Text\", \"text\": \"Câu 6. Trong không gian $Oxyz$, tính khoảng cách từ điểm $M(1; 2; -3)$ đến mặt phẳng ($P$) : $x + 2y - 2z - 2 = 0$.\"}, {\"bbox\": [192, 1473, 295, 1551], \"category\": \"List-item\", \"text\": \"A $\\\\frac{11}{3}$.\"}, {\"bbox\": [535, 1473, 625, 1551], \"category\": \"List-item\", \"text\": \"B $\\\\frac{1}{3}$.\"}, {\"bbox\": [879, 1492, 960, 1534], \"category\": \"List-item\", \"text\": \"C 3.\"}, {\"bbox\": [1224, 1492, 1303, 1534], \"category\": \"List-item\", \"text\": \"D 1.\"}, {\"bbox\": [154, 1561, 1378, 1652], \"category\": \"Text\", \"text\": \"Hướng dẫn giải. $d(M, (P)) = \\\\frac{|1 + 2 \\\\cdot 2 - 2 \\\\cdot (-3) - 2|}{\\\\sqrt{1^2 + 2^2 + (-2)^2}} = \\\\frac{|1 + 4 + 6 - 2|}{3} = \\\\frac{9}{3} = 3$.\"}, {\"bbox\": [154, 1663, 1177, 1744], \"category\": \"Text\", \"text\": \"Câu 7.统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的最值，统一价格的