"[{\"bbox\": [202, 140, 682, 181], \"category\": \"Text\", \"text\": \"Từ đó ta có hệ bất phương trình:\"}, {\"bbox\": [707, 193, 957, 401], \"category\": \"Formula\", \"text\": \"$$\\n(I) \\\\begin{cases} x \\\\ge 0 \\\\\\\\ y \\\\ge 0 \\\\\\\\ x + 3y \\\\le 15 \\\\\\\\ x + y \\\\le 10 \\\\end{cases}\\n$$\"}, {\"bbox\": [202, 429, 1152, 471], \"category\": \"Text\", \"text\": \"Số tiền mà hộ nông dân đó thu được là: $F = 3x + 5y$ (triệu đồng).\"}, {\"bbox\": [202, 489, 1448, 532], \"category\": \"Text\", \"text\": \"Bài toán trở thành tìm giá trị lớn nhất của biểu thức $F = 3x + 5y$ với điều kiện hệ (I).\"}, {\"bbox\": [154, 551, 1545, 637], \"category\": \"Text\", \"text\": \"Trong mặt phẳng tọa độ $Oxy$, vẽ các đường thẳng: $d: x = 0$; $d_1: y = 0$; $d_2: x + 3y = 15$; $d_3: x + y = 10$.\"}, {\"bbox\": [358, 648, 1341, 1360], \"category\": \"Picture\"}, {\"bbox\": [202, 1395, 1375, 1438], \"category\": \"Text\", \"text\": \"Miền nghiệm của hệ bất phương trình là tức giác $OABC$ (kể cả biên) với các định:\"}, {\"bbox\": [202, 1459, 725, 1500], \"category\": \"Text\", \"text\": \"$O(0; 0)$, $A(0; 5)$, $B(7, 5; 2, 5)$, $C(10; 0)$.\"}, {\"bbox\": [202, 1518, 881, 1559], \"category\": \"Text\", \"text\": \"Giá trị của biểu thức $F = 3x + 5y$ tại các định:\"}, {\"bbox\": [195, 1581, 709, 1620], \"category\": \"Formula\", \"text\": \"$$\\n\\\\diamond \\\\text{Tại } O(0; 0) : F = 3 \\\\cdot 0 + 5 \\\\cdot 0 = 0.\\n$$\"}, {\"bbox\": [195, 1640, 725, 1678], \"category\": \"Formula\", \"text\": \"$$\\n\\\\diamond \\\\text{Tại } A(0; 5) : F = 3 \\\\cdot 0 + 5 \\\\cdot 5 = 25.\\n$$\"}, {\"bbox\": [195, 1698, 1062, 1737], \"category\": \"Formula\", \"text\": \"$$\\n\\\\diamond \\\\text{Tại } B(7, 5; 2, 5) : F = 3 \\\\cdot 7, 5 + 5 \\\\cdot 2, 5 = 22, 5 + 12, 5 = 35.\\n$$\"}, {\"bbox\": [195, 1757, 758, 1795], \"category\": \"Formula\", \"text\": \"$$\\n\\\\diamond \\\\text{Tại } C(10; 0) : F = 3 \\\\cdot 10 + 5 \\\\cdot 0 = 30.\\n$$\"}, {\"bbox\": [154, 1817, 1178, 1857], \"category\": \"Text\", \"text\": \"So sánh các giá trị trên, ta thấy giá trị lớn nhất của $F$ là 35 triệu đồng.\"}, {\"bbox\": [202, 1876, 1139, 1917], \"category\": \"Text\", \"text\": \"Vậy số tiền người nông dân thu được nhiều nhất là 35 triệu đồng.\"}, {\"bbox\": [154, 1938, 1547, 2113], \"category\": \"Text\", \"text\": \"### 4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.4.