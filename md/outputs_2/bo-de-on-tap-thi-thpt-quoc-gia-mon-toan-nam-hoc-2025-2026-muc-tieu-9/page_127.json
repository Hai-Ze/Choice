"[{\"bbox\": [188, 138, 1546, 226], \"category\": \"List-item\", \"text\": \"d) Lượng nước trong bể lớn nhất trong khoảng thời gian từ 9 giờ sáng đến 18 giờ chiều là 700 gallon nước.\"}, {\"bbox\": [153, 241, 198, 282], \"category\": \"Picture\"}, {\"bbox\": [204, 241, 450, 304], \"category\": \"Text\", \"text\": \"Hướng dẫn giải.\"}, {\"bbox\": [153, 243, 1546, 332], \"category\": \"Text\", \"text\": \"a) Sai Do $t = 0$ tại thời điểm 6 giờ sáng nên tại thời điểm 9 giờ sáng thì $t = 3$.\"}, {\"bbox\": [153, 339, 695, 381], \"category\": \"Text\", \"text\": \"Ta có $f(3) = 100 \\\\cdot 3 = 300$ gallon/giờ.\"}, {\"bbox\": [204, 401, 1206, 442], \"category\": \"Text\", \"text\": \"b) Đúng Với $t = 3$, $100t = -200t + a \\\\Leftrightarrow -600 + a = 300 \\\\Leftrightarrow a = 900$.\"}, {\"bbox\": [153, 459, 1546, 546], \"category\": \"Text\", \"text\": \"c) Sai Tại 11 giờ trưa (tương đương $t = 5$), tốc độ thay đổi lượng nước trong bể là $f(5) = -200 \\\\cdot 5 + 900 = -100$ gallon/giờ.\"}, {\"bbox\": [153, 548, 1546, 636], \"category\": \"Text\", \"text\": \"Tại 15 giờ chiều (tương đương $t = 9$), tốc độ thay đổi lượng nước trong bể là $f(9) = 100 \\\\cdot 9 - 900 = 0$ gallon/giờ.\"}, {\"bbox\": [204, 654, 1048, 696], \"category\": \"Text\", \"text\": \"d) Đúng Từ 9 giờ sáng đến 18 giờ chiều tức là $3 \\\\le t \\\\le 12$.\"}, {\"bbox\": [153, 700, 753, 741], \"category\": \"Text\", \"text\": \"Từ $3 \\\\le t \\\\le 9$, lượng nước đang giảm về 0.\"}, {\"bbox\": [153, 743, 957, 785], \"category\": \"Text\", \"text\": \"Lượng nước trong bể bắt đầu tăng trở lại từ $9 \\\\le t \\\\le 12$.\"}, {\"bbox\": [153, 787, 955, 829], \"category\": \"Text\", \"text\": \"Lượng nước trong bể từ 15 giờ chiều đến 18 giờ chiều là\"}, {\"bbox\": [621, 835, 1077, 926], \"category\": \"Formula\", \"text\": \"$$\\n250 + \\\\int_{9}^{12} (100t - 900)dt = 700.\\n$$\"}, {\"bbox\": [153, 950, 190, 984], \"category\": \"Picture\"}, {\"bbox\": [196, 947, 1546, 1254], \"category\": \"Text\", \"text\