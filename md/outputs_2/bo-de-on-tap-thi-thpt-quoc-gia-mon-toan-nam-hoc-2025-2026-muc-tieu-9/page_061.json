"[{\"bbox\": [153, 132, 911, 299], \"category\": \"Formula\", \"text\": \"$$\\n\\\\text{Vì } \\\\begin{cases} (SAB) \\\\perp (ABCD) \\\\\\\\ (SAB) \\\\cap (ABCD) = AB \\\\quad \\\\Rightarrow \\\\ SH \\\\perp (ABCD). \\\\\\\\ SH \\\\subset (SAB), SH \\\\perp AB \\\\end{cases}\\n$$\"}, {\"bbox\": [153, 299, 932, 341], \"category\": \"Text\", \"text\": \"Trong mặt phẳng $(ABCD)$, kẻ $HK \\\\perp BD$ ($K \\\\in BD$).\"}, {\"bbox\": [153, 341, 919, 385], \"category\": \"Text\", \"text\": \"Trong mặt phẳng $(SHK)$, kẻ $HM \\\\perp SK$ ($M \\\\in SK$).\"}, {\"bbox\": [153, 385, 1252, 489], \"category\": \"Formula\", \"text\": \"$$\\n\\\\text{Ta có: } \\\\begin{cases} BD \\\\perp HK \\\\\\\\ BD \\\\perp SH \\\\text{ (do } SH \\\\perp (ABCD)) \\\\end{cases} \\\\Rightarrow BD \\\\perp (SHK) \\\\Rightarrow BD \\\\perp HM.\\n$$\"}, {\"bbox\": [153, 493, 1076, 535], \"category\": \"Text\", \"text\": \"Mà $HM \\\\perp SK$ nên $HM \\\\perp (SBD)$. Do đó $d(H, (SBD)) = HM$.\"}, {\"bbox\": [202, 555, 655, 595], \"category\": \"Text\", \"text\": \"Xét hình vuông $ABCD$ cạnh 2:\"}, {\"bbox\": [195, 605, 978, 684], \"category\": \"List-item\", \"text\": \"* Đường chéo $AC = BD = 2\\\\sqrt{2} \\\\Rightarrow AO = \\\\frac{1}{2}AC = \\\\sqrt{2}$.\"}, {\"bbox\": [195, 691, 1546, 778], \"category\": \"List-item\", \"text\": \"* Vì $H$ là trung điểm $AB$ và $HK // AO$ (cùng vuông góc $BD$) nên $HK$ là đường trung bình của tam giác $ABO$.\"}, {\"bbox\": [195, 786, 622, 874], \"category\": \"List-item\", \"text\": \"* Suy ra $HK = \\\\frac{1}{2}AO = \\\\frac{\\\\sqrt{2}}{2}$.\"}, {\"bbox\": [202, 886, 802, 926], \"category\": \"Text\", \"text\": \"Trong tam giác vuông $SHK$ tại $H$, ta có:\"}, {\"bbox\": [329, 932, 1373, 1046], \"category\": \"Formula\", \"text\": \"$$\\n\\\\frac{1}{HM^2} = \\\\frac{1}{SH^2} + \\\\frac{1}{HK^2} = \\\\frac{1}{3} + \\\\frac{1}{\\\\left(\\\\frac{\\\\sqrt{2}}{2}\\\\right)^2} = \\\\frac{1}{3} + 2 = \\\\frac{7}{3} \\\\Rightarrow HM = \\\\sqrt{\\\\frac{3}{7}} = \\\\frac{\\\\sqrt{21}}{7}.\\n$$\"}, {\"bbox\": [153, 1050, 813, 1093], \"category\": \"Text\", \"text\": \"Ta có đường thẳng $AH$ cắt $(SBD)$ tại $B$ nên:\"}, {\"bbox\": [371, 1101, 1331, 1191], \"category\": \"Formula\", \"text\": \"$$\\n\\\\frac{d(A, (SBD))}{d(H, (SBD))} = \\\\frac{AB}{HB} = 2 \\\\Rightarrow d(A, (SBD)) = 2HM = \\\\frac{2\\\\sqrt{21}}{7} \\\\approx 1,31.\\n$$\"}, {\"bbox\": [153, 1197, 989, 1239], \"category\": \"Text\", \"text\": \"Vậy khoảng cách từ $A$ đến mặt phẳng $(SBD)$ xấp xỉ 1,31.\"}, {\"bbox\": [153, 1257, 1546, 1405], \"category\": \"Text\", \"text\": \"### 2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4.2.4