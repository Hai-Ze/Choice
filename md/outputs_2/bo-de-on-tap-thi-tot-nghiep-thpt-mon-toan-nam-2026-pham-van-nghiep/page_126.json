    ],
    "category": "Text",
    "text": "Lời giải"
  },
  {
    "bbox": [
      212,
      660,
      1303,
      704
    ],
    "category": "Text",
    "text": "Gọi $A$ là biến cố “Sản phẩm được kiểm tra là của phân xưởng I sản xuất”."
  },
  {
    "bbox": [
      212,
      704,
      891,
      749
    ],
    "category": "Text",
    "text": "$B$ là biến cố “Sản phẩm được kiểm tra bị lỗ”."
  },
  {
    "bbox": [
      212,
      751,
      859,
      807
    ],
    "category": "Text",
    "text": "Theo bài ra ta có: $P(A) = 0,65, P(\\bar{A}) = 0,35$."
  },
  {
    "bbox": [
