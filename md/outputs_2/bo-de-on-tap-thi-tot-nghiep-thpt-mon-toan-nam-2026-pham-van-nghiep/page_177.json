    ],
    "category": "Table",
    "text": "<table><tr><td>$x$</td><td>0</td><td>8</td><td>20</td></tr><tr><td>$f'(x)$</td><td>-</td><td>0</td><td>+</td></tr><tr><td>$f(x)$</td><td>$+\\infty$</td><td>$10\\sqrt{5}$</td><td>$+\\infty$</td></tr></table>"
  },
