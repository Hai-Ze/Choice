"[{\"bbox\": [96, 57, 349, 94], \"category\": \"Page-header\", \"text\": \"Ngày 30 - 11 - 2025\"}, {\"bbox\": [96, 134, 1499, 181], \"category\": \"Text\", \"text\": \"**Câu 8.** Trong một tam giác $ABC$ bất kì, có bao nhiêu vector được tạo thành từ các định của tam giác ?\"}, {\"bbox\": [234, 204, 315, 237], \"category\": \"List-item\", \"text\": \"A. 6.\"}, {\"bbox\": [572, 204, 651, 237], \"category\": \"List-item\", \"text\": \"B. 4.\"}, {\"bbox\": [888, 204, 965, 237], \"category\": \"List-item\", \"text\": \"C. 3.\"}, {\"bbox\": [1204, 204, 1283, 237], \"category\": \"List-item\", \"text\": \"D. 0.\"}, {\"bbox\": [96, 246, 1534, 344], \"category\": \"Text\", \"text\": \"**Câu 9.** Cho lăng trụ $ABC.A'B'C'$ có thể tích $V = 6$ và tổng diện tích hai mặt đáy là 4 thì khoảng cách từ điểm $B'$ đến mặt phẳng $(ABC)$ bằng ?\"}, {\"bbox\": [234, 359, 307, 392], \"category\": \"List-item\", \"text\": \"A. 1.\"}, {\"bbox\": [572, 359, 651, 392], \"category\": \"List-item\", \"text\": \"B. 6.\"}, {\"bbox\": [888, 359, 965, 392], \"category\": \"List-item\", \"text\": \"C. 9.\"}, {\"bbox\": [1204, 359, 1283, 392], \"category\": \"List-item\", \"text\": \"D. 3.\"}, {\"bbox\": [84, 420, 1489, 533], \"category\": \"Text\", \"text\": \"**Câu 10.** Cho $f(x)$ là hàm số liên tục trên đoạn $[0;1]$. $F(x)$ là một nguyên hàm của hàm số $f(x)$ trên đoạn $[0;1]$. Khi đó, hiệu số $F(0)-F(1)$ bằng ?\"}, {\"bbox\": [234, 564, 456, 630], \"category\": \"List-item\", \"text\": \"A. $-\\\\int_{0}^{1} F(x)dx$.\"}, {\"bbox\": [572, 564, 766, 630], \"category\": \"List-item\", \"text\": \"B. $\\\\int_{0}^{1} f(x)dx$.\"}, {\"bbox\": [888, 564, 1086, 630], \"category\": \"List-item\", \"text\": \"C. $\\\\int_{0}^{1} F(x)dx$.\"}, {\"bbox\": [1204, 564, 1406, 630], \"category\": \"List-item\", \"text\": \"D. $\\\\int_{1}^{0} f(x)dx$.\"}, {\"bbox\": [84, 641, 1501, 752], \"category\": \"Text\", \"text\": \"**Câu 11.** Trong không gian $Oxyz$, cho hai mặt phẳng $(P): 2x+y-2z-1=0$, $(Q): 6x+3y-6z+15=0$. Khoảng cách giữa hai mặt phẳng $(P)$ và $(Q)$ bằng ?\"}, {\"bbox\": [234, 767, 315, 822], \"category\": \"List-item\", \"text\": \"A. 2.\"}, {\"bbox\": [572, 767, 655, 847], \"category\": \"List-item\", \"text\": \"B. $\\\\frac{4}{3}$.\"}, {\"bbox\": [888, 767, 982, 847], \"category\": \"List-item\", \"text\": \"C. $\\\\frac{16}{9}$.\"}, {\"bbox\": [1204, 767, 1302, 847], \"category\": \"List-item\", \"text\": \"D. $\\\\frac{16}{3}$.\"}, {\"bbox\": [84, 873, 1415, 924], \"category\": \"Text\", \"text\": \"**Câu 12.** Một mặt cầu $(S)$ có tâm là $I = (1;-2;3)$ tiếp xúc với trục tung thì có bán kính $R$ bằng ?\"}, {\"bbox\": [234, 951, 341, 998], \"category\": \"List-item\", \"text\": \"A. $\\\\sqrt{14}$\"}, {\"bbox\": [572, 962, 663, 998], \"category\": \"List-item\", \"text\": \"B. 14.\"}, {\"bbox\": [888, 951, 1005, 998], \"category\": \"List-item\", \"text\": \"C. $\\\\sqrt{10}$.\"}, {\"bbox\": [1204, 962, 1293, 998], \"category\": \"List-item\", \"text\": \"D. 10.\"}, {\"bbox\": [96, 1083, 596, 1135], \"category\": \"Section-header\", \"text\": \"## Part 2: Trắc nghiệm đúng sai\"}, {\"bbox\": [96, 1153, 1389, 1257], \"category\": \"Text\", \"text\": \"**Câu 1.** Mộ"