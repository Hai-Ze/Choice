    ],
    "category": "Table",
    "text": "<table><tr><td>$x$</td><td>0</td><td>$\\frac{1}{\\ln 2}$</td><td>$+\\infty$</td></tr><tr><td>$g'(x)$</td><td>-</td><td>0</td><td>+</td></tr><tr><td>$g(x)$</td><td colspan=\"3\">$+\\infty$<br>$g(\\frac{1}{\\ln 2})$<br>$+\\infty$</td></tr></table>"
  },
  {
    "bbox": [
      251,
