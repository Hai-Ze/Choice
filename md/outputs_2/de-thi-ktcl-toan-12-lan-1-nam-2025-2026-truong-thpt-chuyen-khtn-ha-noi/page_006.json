  {
    "bbox": [
      586,
      510,
      861,
      591
    ],
    "category": "List-item",
    "text": "B. $\\frac{1}{2}x^2 - \\cos x + C$."
  },
  {
    "bbox": [
      901,
      528,
      1146,
      568
    ],
    "category": "List-item",
    "text": "C. $x^2 - \\cos x + C$."
