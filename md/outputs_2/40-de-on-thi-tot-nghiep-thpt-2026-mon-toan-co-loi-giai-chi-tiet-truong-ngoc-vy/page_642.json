    ],
    "category": "Text",
    "text": "$B$: “Học sinh tham gia biểu diễn thể thao”"
  },
  {
    "bbox": [
      155,
      510,
      520,
      548
    ],
    "category": "Text",
    "text": "Giả sử $P(A) = x, 0 \\le x \\le 1$."
  },
  {
    "bbox": [
      155,
      570,
      368,
      614
    ],
    "category": "Text",
    "text": "Sơ đồ hình cây:"
