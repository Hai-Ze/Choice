"[{\"bbox\": [162, 56, 952, 95], \"category\": \"Page-header\", \"text\": \"40 Д‘б»Ғ Гҙn thi tб»‘t nghiб»Үp PTTH mГҙn toГЎn NДғm 2026 cГі lб»қi giбәЈi chi tiбәҝt\"}, {\"bbox\": [1168, 59, 1531, 95], \"category\": \"Page-header\", \"text\": \"TrЖ°ЖЎng Ngб»Қc Vб»№ 0978 333 093\"}, {\"bbox\": [155, 95, 1573, 195], \"category\": \"Section-header\", \"text\": \"PHбәҰN II. ThГӯ sinh trбәЈ lб»қi tб»« cГўu 1 Д‘бәҝn cГўu 4. Trong mб»—i ГҪ a), b), c), d) б»ҹ mб»—i cГўu, thГӯ sinh chб»Қn Д‘Гәng hoбә·c sai.\"}, {\"bbox\": [155, 216, 681, 303], \"category\": \"Text\", \"text\": \"**CГўu 1.** Cho hГ m sб»‘ $y = \\\\frac{x^2 - 8x + 9}{x - 5}$.\"}, {\"bbox\": [155, 324, 829, 374], \"category\": \"Text\", \"text\": \"a) Tбәӯp xГЎc Д‘б»Ӣnh cб»§a hГ m sб»‘ Д‘ГЈ cho lГ  $D = \\\\mathbb{R} \\\\setminus \\\\{5\\\\}$.\"}, {\"bbox\": [155, 401, 862, 501], \"category\": \"Text\", \"text\": \"b) ДҗбәЎo hГ m cб»§a hГ m sб»‘ Д‘ГЈ cho lГ  $y' = \\\\frac{x^2 - 10x + 31}{(x - 5)^2}$.\"}, {\"bbox\": [155, 527, 835, 577], \"category\": \"Text\", \"text\": \"c) HГ m sб»‘ Д‘ГЈ cho nghб»Ӣch biбәҝn trГӘn khoбәЈng $(4;10)$.\"}, {\"bbox\": [155, 597, 629, 643], \"category\": \"Text\", \"text\": \"d) HГ m sб»‘ Д‘ГЈ cho khГҙng cГі cб»ұc trб»Ӣ.\"}, {\"bbox\": [155, 661, 1573, 882], \"category\": \"Text\", \"text\": \"**CГўu 2.** Trong khГҙng gian vб»ӣi hб»Ү trб»Ҙc tб»Қa Д‘б»ҷ $Oxyz$, cho Д‘Ж°б»қng thбәіng $d: x = \\\\frac{y-1}{2} = \\\\frac{z-2}{-1}$ vГ  mбә·t phбәіng $(P): 3x + y - z - 5 = 0$. Mбә·t cбә§u $(S)$ cГі tГўm $I$ thuб»ҷc Д‘Ж°б»қng thбәіng $d$ vГ  cбәҜt mбә·t phбәіng $(P)$ theo giao tuyбәҝn lГ  Д‘Ж°б»қng trГІn lб»ӣn nhбәҘt cГі bГЎn kГӯnh $r = 5$.\"}, {\"bbox\": [155, 901, 864, 952], \"category\": \"Text\", \"text\": \"a) Mбә·t phбәіng $(P)$ cГі vectЖЎ phГЎp tuyбәҝn $\\\\vec{n} = (3;1;-1)$.\"}, {\"bbox\": [155, 977, 950, 1125], \"category\": \"Text\", \"text\": \"b) ДҗЖ°б»қng thбәіng $d$ cГі phЖ°ЖЎng trГ¬nh tham sб»‘ lГ  $\\\\begin{cases} x = t \\\\\\\\ y = 1 + 2t \\\\\\\\ z = 2 - t \\\\end{cases}