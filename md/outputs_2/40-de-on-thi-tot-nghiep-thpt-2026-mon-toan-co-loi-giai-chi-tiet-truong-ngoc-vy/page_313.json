    ],
    "category": "Text",
    "text": "**Đáp án:** 0,92"
  },
  {
    "bbox": [
      75,
      623,
      702,
      667
    ],
    "category": "Text",
    "text": "Gọi $N$ là xác suất bị nhiễm và $D$ là dương tính"
  },
  {
    "bbox": [
      82,
      688,
      609,
      769
    ],
    "category": "Formula",
    "text": "$$\nP(N) = \\frac{80}{200} \\Rightarrow P(\\overline{N}) = 1 - \\frac{80}{200} = \\frac{120}{200},\n$$"
  },
  {
    "bbox": [
      82,
      794,
      537,
      850
    ],
    "category": "Formula",
    "text": "$$\nP(D/N) = 0,9; \\quad P(D/\\overline{N}) = 0,05\n$$"
  },
  {
    "bbox": [
      82,
      880,
      557,
      962
    ],
    "category": "Formula",
    "text": "$$\nP(D) = \\frac{80}{200} \\cdot 0,9 + \\frac{120}{200} \\cdot 0,05 = 0,39\n$$"
  },
  {
    "bbox": [
      82,
      987,
      708,
      1113
    ],
    "category": "Formula",
    "text": "$$\nP(N/D) = \\frac{P(N) \\cdot P(D/N)}{P(D)} = \\frac{\\frac{80}{200} \\cdot 0,9}{0,39} = 0,92\n$$"
  },
