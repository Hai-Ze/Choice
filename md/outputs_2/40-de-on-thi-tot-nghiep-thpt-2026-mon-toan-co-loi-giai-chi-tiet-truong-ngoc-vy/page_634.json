      404,
      1071,
      448
    ],
    "category": "Text",
    "text": "**Câu 11.** Cho hình集合 $ABCD.A'B'C'D'$. Mind đề nào sau đây sai?"
  },
  {
    "bbox": [
      205,
      471,
      526,
      518
    ],
    "category": "List-item",
    "text": "A. $(ACD') \\parallel (A'C'B)$."
  },
  {
    "bbox": [
      905,
      471,
      1271,
      518
    ],
    "category": "List-item",
    "text": "B. $(ABB'A') \\parallel (CDD'C')$."
  },
  {
    "bbox": [
      205,
      545,
      524,
      592
    ],
    "category": "List-item",
    "text": "C. $(BDA') \\parallel (D'B'C)$."
