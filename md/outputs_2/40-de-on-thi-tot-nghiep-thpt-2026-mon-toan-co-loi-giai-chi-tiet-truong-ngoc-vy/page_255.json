    ],
    "category": "Formula",
    "text": "$$\n\\text{Có: } \\begin{cases} (A'BC) \\cap (ABC) = BC \\\\ AN \\perp BC \\\\ A'N \\perp BC \\ (BC \\perp (A'AN)) \\end{cases} \\Rightarrow ((A'BC), (ABC)) = \\widehat{A'NA} = 60^{\\circ}\n$$"
  },
  {
    "bbox": [
      156,
      907,
      964,
      988
    ],
    "category": "Formula",
    "text": "$$\n\\text{Ta có: } d[M, (A'BC)] = \\frac{1}{2} d[B', (A'BC)] = \\frac{1}{2} d[A, (A'BC)]\n$$"
  },
  {
    "bbox": [
      156,
      1010,
      585,
      1050
    ],
    "category": "Formula",
    "text": "$$\n\\text{Dựng } AH \\perp A'N \\text{ và } AH \\perp BC\n$$"
  },
  {
    "bbox": [
      156,
      1072,
      895,
      1153
    ],
    "category": "Formula",
    "text": "$$\n\\text{Suy ra: } AH \\perp (A'BC). \\text{ Do đó } d(M, (A'BC)) = \\frac{1}{2} AH.\n$$"
  },
  {
    "bbox": [
      162,
      1173,
      650,
      1268
    ],
    "category": "Formula",
    "text": "$$\nAH = \\sin 60^{\\circ} \\cdot AN = \\frac{\\sqrt{3}}{2} \\cdot 4 \\frac{\\sqrt{3}}{2} = 3 \\text{cm}.\n$$"
  },
  {
    "bbox": [
      156,
      1292,
      742,
      1374
    ],
    "category": "Formula",
    "text": "$$\n\\text{Vậy } d(M, (A'BC)) = \\frac{1}{2} AH = \\frac{1}{2} \\cdot 3 = 1,5 \\text{cm}.\n$$"
  },
  {
