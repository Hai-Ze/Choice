      199,
      1117,
      281
    ],
    "category": "Text",
    "text": "**Câu 1.** Phương trình $\\sin(x+10^\\circ) = \\frac{1}{2}$ với $0^\\circ < x < 180^\\circ$ có nghiệm là:"
  },
  {
    "bbox": [
      205,
      305,
      516,
      344
    ],
    "category": "List-item",
    "text": "A. $x = 30^\\circ$ và $x = 150^\\circ$"
  },
  {
    "bbox": [
      905,
      305,
      1213,
      344
    ],
    "category": "List-item",
    "text": "B. $x = 20^\\circ$ và $x = 140^\\circ$"
  },
  {
    "bbox": [
      205,
      368,
      518,
      407
    ],
    "category": "List-item",
    "text": "C. $x = 40^\\circ$ và $x = 160^\\circ$"
  },
  {
    "bbox": [
      905,
      368,
      1210,
      407
    ],
    "category": "List-item",
    "text": "D. $x = 30^\\circ$ và $x = 140^\\circ$"
  },
  {
    "bbox": [
      807,
