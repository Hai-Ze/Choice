      1788,
      602,
      1830
    ],
    "category": "Formula",
    "text": "A. $\\overline{AC'} = \\overline{AB} + \\overline{AD} + \\overline{AA'}$."
  },
  {
    "bbox": [
      901,
      1788,
      1120,
      1830
    ],
    "category": "Formula",
    "text": "B. $\\overline{OI} + \\overline{OI'} = \\overline{O}$."
  },
  {
    "bbox": [
      251,
      1838,
      605,
      1884
    ],
    "category": "Formula",
    "text": "C. $\\overline{AB} + \\overline{AA'} = \\overline{AD} + \\overline{DD'}$."
  },
  {
    "bbox": [
      901,
      1841,
      1421,
      1884
    ],
    "category": "Formula",
    "text": "D. $\\overline{AB} + \\overline{BC} + \\overline{CC'} = \\overline{AD'} + \\overline{D'O} + \\overline{OC'}$."
  },
  {
    "bbox": [
      836,
      1892,
