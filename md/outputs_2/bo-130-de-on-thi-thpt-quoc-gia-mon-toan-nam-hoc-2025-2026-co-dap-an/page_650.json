"[{\"bbox\": [53, 47, 410, 79], \"category\": \"Page-header\", \"text\": \"Trường TH-THCS-THPT ......\"}, {\"bbox\": [951, 35, 1554, 78], \"category\": \"Page-header\", \"text\": \"BỘ ĐỀ ÔN THI THPT QUỐC GIA 2025 -2026\"}, {\"bbox\": [141, 120, 327, 155], \"category\": \"Section-header\", \"text\": \"QUICK NOTE\"}, {\"bbox\": [448, 120, 1239, 162], \"category\": \"Text\", \"text\": \"**CÂU 9.** Họ nguyên hàm của hàm số $f(x) = \\\\sin x + \\\\cos x$ là\"}, {\"bbox\": [478, 162, 784, 199], \"category\": \"List-item\", \"text\": \"(A) $-\\\\cos x + \\\\sin x + C$.\"}, {\"bbox\": [1024, 162, 1302, 199], \"category\": \"List-item\", \"text\": \"(B) $\\\\cos x + \\\\sin x + C$.\"}, {\"bbox\": [478, 204, 756, 243], \"category\": \"List-item\", \"text\": \"(C) $\\\\cos x - \\\\sin x + C$.\"}, {\"bbox\": [1024, 204, 1332, 243], \"category\": \"List-item\", \"text\": \"(D) $-\\\\cos x - \\\\sin x + C$.\"}, {\"bbox\": [448, 260, 1554, 369], \"category\": \"Text\", \"text\": \"**CÂU 10.** Cho hàm số $y = \\\\frac{ax + b}{cx + d}$ ($ac \\\\neq 0, ad - bc \\\\neq 0$) có bảng biến thiên như dưới đây.\"}, {\"bbox\": [636, 391, 1365, 673], \"category\": \"Picture\"}, {\"bbox\": [448, 707, 1342, 744], \"category\": \"Text\", \"text\": \"Đường tiệm cận đứng của đồ thị hàm số đã cho có phương trình là\"}, {\"bbox\": [478, 744, 632, 781], \"category\": \"List-item\", \"text\": \"(A) $x = -2$.\"}, {\"bbox\": [750, 744, 900, 781], \"category\": \"List-item\", \"text\": \"(B) $y = -2$.\"}, {\"bbox\": [1024, 744, 1151, 781], \"category\": \"List-item\", \"text\": \"(C) $x = 1$.\"}, {\"bbox\": [1295, 744, 1422, 781], \"category\": \"List-item\", \"text\": \"(D) $y = 1$.\"}, {\"bbox\": [448, 799, 1554, 879], \"category\": \"Text\", \"text\": \"**CÂU 11.** Một người chia thời lượng (đơn vị: giây) thực hiện các cuộc gọi điện thoại của mình trong một tuần thành sáu nhóm và lập bảng tần số ghép nhóm như sau.\"}, {\"bbox\": [555, 907, 1445, 1007], \"category\": \"Table\", \"text\": \"<table><tr><td>Nhóm</td><td>[0; 30)</td><td>[30; 60)</td><td>[60; 90)</td><td>[90; 120)</td><td>[120; 150)</td><td>[150; 180)</td></tr><tr><td>Tần số</td><td>10</td><td>11</td><td>8</td><td>6</td><td>4</td><td>1</td></tr></table>\"}, {\"bbox\": [448, 1048, 1445, 1086], \"category\": \"Text\", \"text\": \"Tứ phân vị thứ ba $Q_3$ (đơn vị: giây) của mẫu số liệu ghép nhóm trên bằng\"}, {\"bbox\": [478, 1086, 578, 1125], \"category\": \"List-item\", \"text\": \"(A) 105.\"}, {\"bbox\": [750, 1086, 854, 1125], \"category\": \"List-item\", \"text\": \"(B) 100.\"}, {\"bbox\": [1024, 1086, 1107, 1125], \"category\": \"List-item\", \"text\": \"(C) 90.\"}, {\"bbox\": [1295, 1086, 1378, 1125], \"category\": \"List-item\", \"text\": \"(D) 95.\"}, {\"bbox\": [448, 1144, 1554, 1261], \"category\": \"Text\", \"text\": \"**CÂU 12.** Cho khối chóp $O.ABC$ có $OA$ vuông góc với mặt phẳng ($ABC$), tam giác $ABC$ vuông tại $A$ và $OA = 2, AB = 3, AC = 6$. Thể tích của khối chóp $O.ABC$ bằng\"}, {\"bbox\": [478, 1261, 563, 1300], \"category\": \"List-item\", \"text\": \"(A) 18.\"}, {\"bbox\": [750, 1261, 821, 1300], \"category\": \"List-item\", \"text\": \"(B) 6.\"}, {\"bbox\": [1024, 1261, 1107, 1300], \"category\": \"List-item\", \"text\": \"(C) 36.\"}, {\"bbox\": [1295, 1261, 1378, 1300], \"category\": \"List-item\", \"text\": \"(D) 12.\"}, {\"bbox\": [448, 1319, 1173, 1374], \"category\": \"Section-header\", \"text\": \"2 CÂU TRẮC NGHIỆM ĐÚNG SAI (4,0 ĐIỂM)\"}, {\"bbox\": [448, 1384, 1554, 1614], \"category\": \"Text\", \"text\": \"**CÂU 1.** Một phần mềm nhận dạng tin-off广宣在电面上以某种方式展示信息，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在电面上，通过某种方式将信息以某种方式展示在