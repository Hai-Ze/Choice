    ],
    "category": "Formula",
    "text": "$$\n\\text{A} \\int f(x) \\, dx = e^{x-2} + C.\n$$"
  },
  {
    "bbox": [
      1023,
      616,
      1414,
      690
    ],
    "category": "Formula",
    "text": "$$\n\\text{B} \\int f(x) \\, dx = e^x + 2x + C.\n$$"
  },
  {
    "bbox": [
      477,
      688,
      801,
      761
    ],
    "category": "Formula",
    "text": "$$\n\\text{C} \\int f(x) \\, dx = e^x + C.\n$$"
  },
  {
    "bbox": [
      1023,
      688,
      1414,
      761
    ],
    "category": "Formula",
    "text": "$$\n\\text{D} \\int f(x) \\, dx = e^x - 2x + C.\n$$"
  },
  {
    "bbox": [
