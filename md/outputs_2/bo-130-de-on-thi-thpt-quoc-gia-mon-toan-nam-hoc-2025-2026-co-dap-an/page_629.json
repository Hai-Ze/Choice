    "bbox": [
      123,
      314,
      408,
      427
    ],
    "category": "Formula",
    "text": "$$\n\\text{A} \\quad V = \\pi \\int_{a}^{b} S(x) \\, dx.\n$$"
  },
  {
    "bbox": [
      668,
      314,
      973,
      427
    ],
    "category": "Formula",
    "text": "$$\n\\text{B} \\quad V = \\pi \\int_{a}^{b} [S(x)]^2 \\, dx.\n$$"
