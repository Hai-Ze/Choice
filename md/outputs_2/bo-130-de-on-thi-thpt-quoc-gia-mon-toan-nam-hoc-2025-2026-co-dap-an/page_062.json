"[{\"bbox\": [54, 48, 76, 76], \"category\": \"Picture\"}, {\"bbox\": [83, 48, 382, 78], \"category\": \"Page-header\", \"text\": \"Trường TH-THCS-THPT ......\"}, {\"bbox\": [387, 48, 409, 76], \"category\": \"Picture\"}, {\"bbox\": [952, 41, 983, 74], \"category\": \"Picture\"}, {\"bbox\": [1001, 35, 1553, 78], \"category\": \"Page-header\", \"text\": \"BỘ ĐỀ ÔN THI THPT QUỐC GIA 2025 -2026\"}, {\"bbox\": [141, 120, 327, 154], \"category\": \"Section-header\", \"text\": \"QUICK NOTE\"}, {\"bbox\": [447, 120, 1555, 275], \"category\": \"Text\", \"text\": \"**CÂU 2.** Khi điều tra sức khoẻ nhiều người cao tuổi ở một địa phương, người ta thấy rằng có 40% người cao tuổi bị bệnh tiểu đường. Bên cạnh đó, số người bị bệnh huyết áp cao trong những người bị bệnh tiểu đường là 70%, trong những người không bị bệnh tiểu đường là 25%. Chọn ngẫu nhiên 1 người cao tuổi để kiểm tra sức khoẻ.\"}, {\"bbox\": [478, 275, 1224, 314], \"category\": \"List-item\", \"text\": \"a) Xác suất chọn được người bị bệnh tiểu đường là 0,4.\"}, {\"bbox\": [478, 316, 1549, 392], \"category\": \"List-item\", \"text\": \"b) Xác suất chọn được người bị bệnh huyết áp cao, biết người đó bị bệnh tiểu đường là 0,7.\"}, {\"bbox\": [478, 394, 1268, 434], \"category\": \"List-item\", \"text\": \"c) Xác suất chọn được người bị bệnh huyết áp cao là 0,57.\"}, {\"bbox\": [478, 436, 1548, 475], \"category\": \"List-item\", \"text\": \"d) Xác suất chọn được người bị tiểu đường biết người đó bị huyết áp cao là 0,65.\"}, {\"bbox\": [447, 493, 1555, 611], \"category\": \"Text\", \"text\": \"**CÂU 3.** Biểu đồ sau mô tả kết quả điều tra đường kính thân của một số cây xoan đào 8 năm tuổi (đơn vị: cm) của một giống cây xoan đào ở hai địa điểm $A$ và $B$ (Kết quả làm tròn đến chữ số hàng đơn vị).\"}, {\"bbox\": [452, 636, 1549, 683], \"category\": \"Caption\", \"text\": \"ĐƯỜNG KÍNH CỦA CÂY XOAN ĐÀO TẠI HAI ĐỊA ĐIỂM $A$ VÀ $B$\"}, {\"bbox\": [456, 707, 1555, 1263], \"category\": \"Picture\"}, {\"bbox\": [478, 1278, 1549, 